              {
                "name": "cId",
                "value": "",
                "type": "path",
                "description": "Conversation ID"
              },
              {
                "name": "mId",
                "value": "",
                "type": "path",
                "description": "Message ID"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Submits an answer to a question asked by an agent in a specific message"
        },
        {
          "info": {
            "name": "Edit an Existing Message in a Conversation",
