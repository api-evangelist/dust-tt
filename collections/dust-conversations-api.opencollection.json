              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Edit an Existing Message in a Conversation"
        },
        {
          "info": {
            "name": "Get Events for a Message",
