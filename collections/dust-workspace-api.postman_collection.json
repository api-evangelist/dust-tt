        {
          "id": "1e5c935b-eaac-4fbd-8349-191e6a45429f",
          "name": "Get Workspace Usage Data",
          "request": {
            "name": "Get Workspace Usage Data",
            "description": {
              "content": "Deprecated: this endpoint will be removed after 2026-06-01.\nUse GET /api/v1/w/{wId}/analytics/export instead.\n\nGet usage data for the workspace identified by {wId} in CSV or JSON format.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "v1",
                "w",
                ":wId",
                "workspace-usage"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "start",
                  "value": "<string>",
                  "description": "(Required) The start date in YYYY-MM or YYYY-MM-DD format"
                },
                {
                  "disabled": false,
                  "key": "end",
                  "value": "<string>",
                  "description": "The end date in YYYY-MM or YYYY-MM-DD format (required when mode is 'range')"
                },
                {
                  "disabled": false,
                  "key": "mode",
                  "value": "<string>",
                  "description": "(Required) The mode of date range selection"
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "<string>",
                  "description": "The output format of the data (defaults to 'csv')"
                },
                {
                  "disabled": false,
                  "key": "table",
                  "value": "<string>",
                  "description": "(Required) The name of the usage table to retrieve:\n- \"users\": The list of users categorized by their activity level.\n- \"assistant_messages\": The list of messages sent by users including the mentioned agents.\n- \"builders\": The list of builders categorized by their activity level.\n- \"assistants\": The list of workspace agents and their corresponding usage.\n- \"feedback\": The list of feedback given by users on the agent messages.\n- \"all\": A concatenation of all the above tables.\n"
                },
                {
                  "disabled": false,
                  "key": "includeInactive",
                  "value": "<boolean>",
                  "description": "Include users and assistants with zero messages in the export (defaults to false)"
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "wId",
                  "description": "(Required) Unique string identifier for the workspace"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "text/csv"
              }
            ],
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}"
                }
              ]
            }
          },
          "response": [
            {
              "id": "0f3f015f-1396-40a7-88ac-a1dd9caf455c",
              "name": "The usage data in CSV or JSON format, or a ZIP of multiple CSVs if table is equal to \"all\"",
